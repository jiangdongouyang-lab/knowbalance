# Copy to .env.role-c.local. Never commit the local file or paste its key into logs/chat.
ROLE_C_MODEL_ENDPOINT=https://your-provider.example/v1/chat/completions
ROLE_C_MODEL_ID=your-model-id
ROLE_C_MODEL_API_KEY=

# json_schema: send the full schema; json_object: request JSON mode (DeepSeek uses this);
# text_json: prompt-only JSON.
ROLE_C_MODEL_RESPONSE_FORMAT=json_schema
# The current rich schemas use conditional/optional fields. Keep false unless the provider
# explicitly supports the full schemas in strict mode; local Ajv validation remains mandatory.
ROLE_C_MODEL_SCHEMA_STRICT=false
# Hybrid reasoning models can spend the output budget before emitting JSON; Author calls normally disable it.
ROLE_C_MODEL_THINKING=disabled

ROLE_C_MODEL_TIMEOUT_MS=120000
ROLE_C_MODEL_MAX_RETRIES=2
ROLE_C_MODEL_AUTH_HEADER=authorization
ROLE_C_MODEL_AUTH_SCHEME=Bearer

# staged is the normal path; monolithic is retained for compatibility/benchmark comparison.
ROLE_C_MODEL_GENERATION_STRATEGY=staged

# Natural staged boundaries. Keep concurrency=1 until the selected API's rate limits are known.
ROLE_C_MODEL_CONCEPT_GROUP_SIZE=1
ROLE_C_MODEL_CONCEPT_CONCURRENCY=1
ROLE_C_MODEL_CONCEPT_SEGMENT_MAX_TOKENS=3500
ROLE_C_MODEL_CODE_LAB_PUBLIC_MAX_TOKENS=3500
ROLE_C_MODEL_CODE_LAB_SECURE_MAX_TOKENS=5000
ROLE_C_MODEL_ASSESSMENT_PUBLIC_MAX_TOKENS=4500
ROLE_C_MODEL_ASSESSMENT_SECURE_MAX_TOKENS=5500

# Monolithic compatibility/benchmark budgets.
ROLE_C_MODEL_CONCEPT_MAX_TOKENS=8000
ROLE_C_MODEL_CODE_LAB_MAX_TOKENS=7000
ROLE_C_MODEL_ASSESSMENT_MAX_TOKENS=8000
