{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jiangdongouyang-lab/knowbalance/schemas/role-c-content/alignment_critic_judgment.schema.json",
  "title": "Role C Model Critic Judgment",
  "type": "object",
  "required": ["checks"],
  "properties": {
    "checks": {
      "type": "array",
      "maxItems": 30,
      "items": {
        "type": "object",
        "required": ["target_artifact_id", "objective_id", "issue_type", "severity", "evidence_refs", "proposed_action"],
        "properties": {
          "target_artifact_id": { "type": "string", "minLength": 1 },
          "objective_id": { "type": "string", "minLength": 1 },
          "issue_type": {
            "enum": [
              "unsupported_claim", "unmeasurable_objective", "missing_prerequisite",
              "undeclared_prerequisite", "difficulty_mismatch", "unexecutable_task",
              "answer_key_conflict", "missing_instruction", "missing_practice",
              "missing_assessment", "mapping_conflict"
            ]
          },
          "severity": { "enum": ["warning", "critical"] },
          "evidence_refs": {
            "type": "array", "minItems": 1, "maxItems": 20, "uniqueItems": true,
            "items": { "type": "string", "minLength": 1, "maxLength": 200 }
          },
          "proposed_action": { "type": "string", "minLength": 1, "maxLength": 1000 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
