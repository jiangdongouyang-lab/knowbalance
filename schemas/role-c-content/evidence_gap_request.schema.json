{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jiangdongouyang-lab/knowbalance/schemas/role-c-content/evidence_gap_request.schema.json",
  "title": "C to A Evidence Gap Request",
  "type": "object",
  "required": ["schema_version", "request_id", "run_id", "target_source_ids", "missing_type", "reason", "learner_level", "required_facts"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "request_id": { "type": "string" }, "run_id": { "type": "string" },
    "target_source_ids": { "type": "array", "items": { "type": "string", "pattern": "^K[0-9]{3}$" } },
    "missing_type": { "enum": ["knowledge_item", "fact", "example", "practice_task", "quiz_seed", "strong_match"] },
    "reason": { "type": "string", "minLength": 1 },
    "learner_level": { "enum": ["beginner", "basic", "intermediate", "integrated"] },
    "required_facts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_id", "fact_id"],
        "properties": {
          "source_id": { "type": "string", "pattern": "^K[0-9]{3}$" },
          "fact_id": { "type": "string", "pattern": "^F[0-9]{3}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
