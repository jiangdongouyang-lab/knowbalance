{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jiangdongouyang-lab/knowbalance/schemas/role-c-content/learning_evidence_event.schema.json",
  "title": "C Learning Evidence Event",
  "type": "object",
  "required": ["schema_version", "event_id", "learner_id_hash", "profile_version", "path_node_id", "objective_id", "source_id", "evidence", "misconceptions", "recommendation", "provenance"],
  "properties": {
    "schema_version": { "const": "1.0" }, "event_id": { "type": "string" }, "learner_id_hash": { "type": "string" },
    "profile_version": { "type": "string" }, "path_node_id": { "type": "string" }, "objective_id": { "type": "string" },
    "source_id": { "type": "string", "pattern": "^K[0-9]{3}$" },
    "evidence": {
      "type": "object", "required": ["modality", "raw_score", "evidence_score", "grader_confidence", "hint_level", "attempt_no"],
      "properties": {
        "modality": { "enum": ["mcq", "true_false", "trace", "short_answer", "code"] },
        "raw_score": { "type": "number" }, "evidence_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "grader_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "hint_level": { "type": "integer", "minimum": 0, "maximum": 3 }, "attempt_no": { "type": "integer", "minimum": 1 }
      }
    },
    "misconceptions": { "type": "array", "items": { "type": "string" } },
    "recommendation": {
      "type": "object", "required": ["action", "confidence", "reason_codes"],
      "properties": {
        "action": { "enum": ["remediate", "reinforce", "advance", "reprofile"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "reason_codes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "provenance": {
      "type": "object", "required": ["artifact_id", "item_id", "grader_version"],
      "properties": { "artifact_id": { "type": "string" }, "item_id": { "type": "string" }, "grader_version": { "type": "string" } }
    }
  },
  "additionalProperties": false
}
