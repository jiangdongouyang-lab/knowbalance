{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jiangdongouyang-lab/knowbalance/schemas/role-c-content/rubric_judgment.schema.json",
  "title": "C Blind Rubric Judgment",
  "type": "object",
  "required": ["criteria"],
  "properties": {
    "criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["criterion_id", "status", "confidence"],
        "properties": {
          "criterion_id": { "type": "string", "minLength": 1 },
          "status": { "enum": ["met", "unmet", "uncertain"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence_excerpt": { "type": "string", "maxLength": 160 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
