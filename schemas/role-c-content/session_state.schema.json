{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jiangdongouyang-lab/knowbalance/schemas/role-c-content/session_state.schema.json",
  "title": "D to C Session State",
  "type": "object",
  "required": ["schema_version", "session_id", "run_id", "learner_id_hash", "current_path_node_id", "attempt_no", "revealed_hint_levels", "public_artifact_refs", "secure_artifact_refs"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "session_id": { "type": "string" }, "run_id": { "type": "string" },
    "learner_id_hash": { "type": "string" }, "current_path_node_id": { "type": "string" },
    "current_form_id": { "type": "string" }, "attempt_no": { "type": "integer", "minimum": 1 },
    "revealed_hint_levels": {
      "type": "object", "additionalProperties": { "type": "integer", "minimum": 0, "maximum": 3 }
    },
    "public_artifact_refs": { "type": "array", "items": { "type": "string" } },
    "secure_artifact_refs": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
