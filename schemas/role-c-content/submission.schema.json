{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jiangdongouyang-lab/knowbalance/schemas/role-c-content/submission.schema.json",
  "title": "C Submission Envelope",
  "type": "object",
  "required": ["schema_version", "submission_id", "run_id", "learner_id_hash", "form_id", "attempt_no", "answers"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "submission_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "learner_id_hash": { "type": "string", "minLength": 1 },
    "form_id": { "type": "string", "minLength": 1 },
    "attempt_no": { "type": "integer", "minimum": 1 },
    "answers": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["item_id", "hint_level_used"],
        "properties": {
          "item_id": { "type": "string", "minLength": 1 },
          "selected_option_id": { "type": "string", "minLength": 1 },
          "text_response": { "type": "string" },
          "code_response": { "type": "string" },
          "hint_level_used": { "type": "integer", "minimum": 0, "maximum": 3 }
        },
        "oneOf": [
          { "required": ["selected_option_id"] },
          { "required": ["text_response"] },
          { "required": ["code_response"] }
        ],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
